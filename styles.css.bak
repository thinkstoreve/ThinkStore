:root{--bg:#f5f5f7;--card:#fff;--text:#161617;--muted:#6e6e73;--border:#e6e6ea;--blue:#0071e3;--green:#25d366;--shadow:0 20px 55px #0002}body.dark{--bg:#08080a;--card:#151518;--text:#f5f5f7;--muted:#bbb;--border:#2a2a2e}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif}img{max-width:100%;display:block}a{text-decoration:none;color:inherit}.top{position:sticky;top:0;z-index:50;background:#ffffffd8;backdrop-filter:blur(18px);display:flex;justify-content:space-between;gap:14px;align-items:center;padding:16px 4%;border-bottom:1px solid #0001}.dark .top{background:#111d}.brand{display:flex;align-items:center;gap:14px}.brand img{width:70px;height:70px;border-radius:50%;object-fit:cover;box-shadow:var(--shadow)}.brand b{font-size:25px}.brand small{display:block;color:var(--muted)}nav{display:flex;gap:9px;overflow-x:auto}nav a,nav button{background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:22px;padding:13px 17px;white-space:nowrap;font-weight:800;cursor:pointer}.hero{min-height:720px;background:radial-gradient(circle at 80% 20%,#0071e355,transparent 25%),linear-gradient(135deg,#020202,#171719);color:white;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:70px 5%;overflow:hidden}.biglogo{width:135px;height:135px;border-radius:50%;object-fit:cover}.eyebrow{color:#8ab4ff;text-transform:uppercase;letter-spacing:.16em;font-weight:900;font-size:12px}.hero h1{font-size:76px;line-height:.92;letter-spacing:-.07em;margin:10px 0}.hero p{font-size:22px;color:#ddd}.btn{display:inline-flex;border:0;background:#111;color:white;border-radius:999px;padding:14px 24px;margin:5px;font-weight:900;cursor:pointer}.wa{background:var(--green)}.heroimgs{position:relative;min-height:480px}.heroimgs img{position:absolute;object-fit:contain;filter:drop-shadow(0 35px 45px #0008)}.heroimgs img:nth-child(1){width:620px;right:-55px;top:0}.heroimgs img:nth-child(2){width:230px;left:0;bottom:0}.heroimgs img:nth-child(3){width:190px;right:55px;bottom:0}.cats{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin:-45px 5% 30px;position:relative}.cats a{background:var(--card);border:1px solid var(--border);border-radius:28px;padding:25px;text-align:center;box-shadow:var(--shadow)}.cats span{font-size:45px;display:block}.cats b{font-size:22px}.section{padding:65px 5%}.section h2,.promo h2,.banner h2,.location h2{font-size:48px;letter-spacing:-.05em;line-height:1;margin:10px 0}.promo,.location{margin:55px 5%;background:var(--card);border:1px solid var(--border);border-radius:38px;box-shadow:var(--shadow);display:grid;grid-template-columns:1fr 1fr;gap:30px;align-items:center;padding:55px}.promo img{background:#f7f7f9;border-radius:25px;object-fit:contain;max-height:360px}.filters{display:flex;gap:9px;overflow-x:auto;margin-bottom:15px}.filter{border:1px solid var(--border);background:var(--card);color:var(--text);border-radius:999px;padding:12px 17px}.filter.active{background:#111;color:white}#search{width:100%;padding:17px 20px;border:1px solid var(--border);border-radius:20px;background:var(--card);color:var(--text);margin-bottom:22px}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(245px,1fr));gap:18px}.prod{background:var(--card);border:1px solid var(--border);border-radius:28px;padding:16px;cursor:pointer;transition:.2s;min-height:360px}.prod:hover{transform:translateY(-5px);box-shadow:var(--shadow)}.photo{height:210px;background:#7f7f7f10;border-radius:22px;display:grid;place-items:center}.photo img{height:100%;width:100%;object-fit:contain}.tag{display:inline-block;background:#eef3ff;color:#1d5fd1;border-radius:999px;padding:7px 12px;font-weight:900;font-size:12px}.prod h3{font-size:20px;line-height:1.1}.prod p{color:var(--muted);font-size:14px}.banner{margin:30px 5%;border-radius:35px;padding:55px;background:linear-gradient(135deg,#fff,#eef4ff)}.banner.dark{background:linear-gradient(135deg,#050505,#222);color:white}.servgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:15px}.servgrid div{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:23px;font-size:20px}.panels{display:grid;grid-template-columns:1fr 1fr;gap:20px}.panels>div{background:var(--card);border:1px solid var(--border);border-radius:30px;padding:25px;box-shadow:var(--shadow)}.logos{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.logos.pay{grid-template-columns:repeat(3,1fr)}.logos img{border-radius:18px;border:1px solid var(--border);background:white}.location{display:flex;justify-content:space-between}.float{position:fixed;right:18px;bottom:18px;background:var(--green);color:white;border:0;border-radius:999px;padding:15px 22px;font-weight:900;z-index:40}footer{background:#111;color:white;padding:35px 5%;display:flex;justify-content:space-between;gap:20px}footer img{width:80px;height:80px;border-radius:50%;object-fit:cover}.modal{display:none;position:fixed;inset:0;background:#000a;backdrop-filter:blur(6px);z-index:100;padding:18px;overflow:auto}.modal.open{display:block}.card{background:var(--card);color:var(--text);border-radius:30px;max-width:1100px;margin:30px auto;padding:28px;position:relative}.detail{display:grid;grid-template-columns:1fr 1fr;gap:25px}.detail>div:first-child{background:#7f7f7f10;border-radius:25px;padding:15px;display:flex;flex-direction:column;justify-content:center}.detail #mainImg{max-height:430px;width:100%;object-fit:contain}.close{position:absolute;right:18px;top:15px;width:40px;height:40px;border-radius:50%;border:0;background:#7f7f7f22;color:var(--text);font-size:25px}.thumbs{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-top:12px}.thumbs button{width:65px;height:50px;border:1px solid var(--border);border-radius:12px;background:var(--card);padding:3px}.thumbs img{width:100%;height:100%;object-fit:contain}.opts{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}.opt{border:1px solid var(--border);background:var(--card);color:var(--text);border-radius:16px;padding:9px 12px}.opt.sel{background:#111;color:white}#features{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0;list-style:none}#features li{background:#7f7f7f12;border-radius:14px;padding:10px}.form{display:grid;gap:10px}.form input,.form select{padding:14px;border-radius:14px;border:1px solid var(--border);background:var(--card);color:var(--text)}.cartrow{border:1px solid var(--border);border-radius:15px;padding:12px;margin:8px 0;display:flex;justify-content:space-between}@media(max-width:900px){.top{display:block}nav{margin-top:12px}.hero,.promo,.detail,.panels{grid-template-columns:1fr}.hero h1{font-size:50px}.heroimgs{min-height:330px}.heroimgs img:nth-child(1){width:420px}.heroimgs img:nth-child(2){width:170px}.heroimgs img:nth-child(3){width:150px}.cats{grid-template-columns:repeat(3,1fr)}.servgrid{grid-template-columns:1fr 1fr}.location,footer{display:block}}@media(max-width:560px){.brand img{width:55px;height:55px}.brand b{font-size:20px}.hero h1{font-size:40px}.biglogo{width:100px;height:100px}.cats{grid-template-columns:1fr 1fr}.section h2,.promo h2,.banner h2,.location h2{font-size:34px}.promo,.location{padding:28px}.grid{grid-template-columns:1fr 1fr;gap:12px}.prod{padding:10px;min-height:280px}.photo{height:140px}.prod p{display:none}.logos,.logos.pay{grid-template-columns:1fr 1fr}#features{grid-template-columns:1fr}}

/* ===== ThinkStore V3.1: portada corregida ===== */
.hero{
  position:relative !important;
  min-height:760px !important;
  color:white !important;
  display:grid !important;
  grid-template-columns:1fr 1fr !important;
  align-items:center !important;
  padding:70px 5% !important;
  overflow:hidden !important;
  background:#030303 !important;
}
.hero-bg{
  position:absolute !important;
  inset:0 !important;
  background:
    radial-gradient(circle at 78% 30%,rgba(0,113,227,.22),transparent 28%),
    radial-gradient(circle at 20% 70%,rgba(123,97,255,.18),transparent 34%),
    linear-gradient(135deg,#020203 0%,#08080b 46%,#151519 100%) !important;
}
.hero-content{
  position:relative !important;
  z-index:3 !important;
  max-width:760px !important;
}
.hero-products{
  position:absolute !important;
  inset:0 !important;
  z-index:1 !important;
  pointer-events:none !important;
  opacity:.95 !important;
  min-height:auto !important;
}
.hero-products::after{
  content:"" !important;
  position:absolute !important;
  inset:0 !important;
  background:linear-gradient(90deg,#030303 0%,rgba(3,3,3,.88) 28%,rgba(3,3,3,.38) 58%,rgba(3,3,3,.08) 100%) !important;
}
.hero-products img{
  position:absolute !important;
  object-fit:contain !important;
  filter:drop-shadow(0 35px 45px rgba(0,0,0,.55)) !important;
  mix-blend-mode:screen !important;
  background:transparent !important;
}
.hero-products img:nth-child(1){
  width:min(780px,58vw) !important;
  right:2% !important;
  top:8% !important;
  opacity:.78 !important;
}
.hero-products img:nth-child(2){
  width:min(250px,18vw) !important;
  right:46% !important;
  left:auto !important;
  top:34% !important;
  bottom:auto !important;
  opacity:.38 !important;
  transform:rotate(-8deg) !important;
}
.hero-products img:nth-child(3){
  width:min(260px,18vw) !important;
  right:12% !important;
  top:38% !important;
  bottom:auto !important;
  opacity:.48 !important;
  transform:rotate(5deg) !important;
}
.hero::before{
  content:"" !important;
  position:absolute !important;
  inset:0 !important;
  background:linear-gradient(180deg,rgba(0,0,0,.05),rgba(0,0,0,.22)) !important;
  z-index:2 !important;
  pointer-events:none !important;
}
@media(max-width:720px){
  .hero{
    grid-template-columns:1fr !important;
    min-height:680px !important;
    padding:58px 6% 90px !important;
  }
  .hero h1{font-size:44px !important;max-width:96% !important;}
  .hero-text{font-size:18px !important;max-width:92% !important;}
  .hero-products img:nth-child(1){width:520px !important;right:-210px !important;top:16% !important;opacity:.5 !important;}
  .hero-products img:nth-child(2){width:170px !important;right:42% !important;top:55% !important;opacity:.22 !important;}
  .hero-products img:nth-child(3){width:160px !important;right:2% !important;top:58% !important;opacity:.28 !important;}
  .hero-products::after{background:linear-gradient(90deg,#030303 0%,rgba(3,3,3,.78) 55%,rgba(3,3,3,.25) 100%) !important;}
  .quick-cats{margin-top:-36px !important;}
}


/* ===== ThinkStore V4: catálogo por modelo y color ===== */
.card-top{display:flex;justify-content:space-between;align-items:center;gap:8px}
.card-top small{color:var(--muted);font-weight:800;font-size:12px;text-align:right}
.color-strip{display:flex;gap:6px;flex-wrap:wrap;margin:8px 0 4px}
.color-dot{width:22px;height:22px;border-radius:50%;display:block;background:#f5f5f7;border:1px solid var(--border);box-shadow:inset 0 0 0 4px rgba(255,255,255,.85),0 3px 10px rgba(0,0,0,.08)}
.product-card .photo,
.detail-gallery{
  background:
    radial-gradient(circle at 50% 40%, rgba(255,255,255,.95), rgba(245,245,247,.78) 50%, rgba(236,238,242,.92) 100%) !important;
}
body.darkmode .product-card .photo,
body.darkmode .detail-gallery{
  background:
    radial-gradient(circle at 50% 35%, rgba(255,255,255,.08), rgba(255,255,255,.03) 50%, rgba(0,0,0,.28) 100%) !important;
}
.product-card .photo img,
.detail-gallery>img{
  padding:8px;
  object-fit:contain;
  transition:.25s ease;
}
.product-card:hover .photo img{transform:scale(1.035)}
.options .option{font-weight:800}
#storageOptions .option{border-radius:14px}
.filters{position:sticky;top:96px;z-index:12;background:var(--bg);padding:10px 0}
@media(max-width:620px){
  .filters{top:115px}
  .color-dot{width:18px;height:18px}
}


/* ===== ThinkStore V4.2 portada fusionada + catálogo detallado ===== */
.hero-premium{position:relative!important;min-height:760px!important;overflow:hidden!important;background:#030306!important;color:white!important;display:flex!important;align-items:center!important;padding:90px 6%!important}
.hero-bg-layer{position:absolute;inset:0;background:radial-gradient(circle at 72% 32%,rgba(255,154,60,.22),transparent 26%),radial-gradient(circle at 35% 70%,rgba(70,150,255,.14),transparent 35%),linear-gradient(135deg,#020204 0%,#090910 50%,#111116 100%);z-index:0}
.hero-fusion{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.hero-fusion:after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(3,3,6,.98) 0%,rgba(3,3,6,.82) 30%,rgba(3,3,6,.40) 60%,rgba(3,3,6,.18) 100%);z-index:5}
.hero-copy{position:relative;z-index:8;max-width:710px;text-shadow:0 18px 40px rgba(0,0,0,.55)}
.hero-copy h1{font-size:clamp(44px,7vw,94px);line-height:.94;margin:12px 0 18px;letter-spacing:-4px}.hero-copy p{max-width:600px;color:rgba(255,255,255,.82);font-size:19px}.hero-copy .biglogo{width:74px;height:74px;border-radius:50%;object-fit:cover;margin-bottom:18px;box-shadow:0 20px 50px rgba(0,0,0,.4)}
.fusion{position:absolute;object-fit:contain;filter:drop-shadow(0 45px 65px rgba(0,0,0,.55));will-change:transform;animation:floating 7s ease-in-out infinite alternate}.fusion-max{right:-8%;top:2%;width:min(820px,62vw);height:auto;opacity:.56;mix-blend-mode:luminosity;filter:grayscale(1) contrast(1.08) brightness(.9) drop-shadow(0 55px 80px rgba(0,0,0,.8))}.fusion-phone{right:9%;top:18%;width:min(360px,25vw);z-index:3;opacity:.88}.fusion-airpods{right:31%;top:19%;width:min(230px,17vw);z-index:4;opacity:.82;animation-delay:1s}.fusion-air{right:2%;bottom:8%;width:min(260px,18vw);z-index:3;opacity:.55;filter:drop-shadow(0 35px 60px rgba(0,0,0,.55)) blur(.1px)}@keyframes floating{from{transform:translateY(0)}to{transform:translateY(-16px)}}
.prod-head{display:flex;align-items:center;justify-content:space-between;gap:10px}.prod-head small{font-size:11px;color:var(--muted);font-weight:800;text-align:right}.model-line{display:flex;flex-direction:column;gap:2px;margin-top:8px;color:var(--muted);font-size:12px}.model-line b{color:var(--text);font-size:13px}.dots{display:flex;gap:6px;margin-top:10px}.dot{width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,#111,#fff);border:1px solid rgba(0,0,0,.14);box-shadow:inset 0 0 0 4px rgba(255,255,255,.7)}
.prod .photo{background:linear-gradient(180deg,#fff,#f5f5f7)!important;border-radius:28px;overflow:hidden}.prod .photo img{width:100%;height:100%;object-fit:contain!important;padding:16px;filter:drop-shadow(0 18px 22px rgba(0,0,0,.12));transition:.25s ease}.prod:hover .photo img{transform:scale(1.04)}
.detail{max-width:1180px!important}.detail>div:first-child{background:linear-gradient(180deg,#fff,#f5f5f7);border-radius:28px;padding:14px}.detail #mainImg{width:100%;height:520px;object-fit:contain!important;display:block;filter:drop-shadow(0 26px 30px rgba(0,0,0,.14))}.thumbs{display:flex;gap:10px;overflow:auto;padding:12px 0}.thumb{border:1px solid var(--border);border-radius:16px;background:white;padding:5px;min-width:82px}.thumb.sel{outline:2px solid #111}.thumb img{width:70px;height:70px;object-fit:contain}.product-meta{display:flex;flex-wrap:wrap;gap:8px;margin:12px 0 18px}.product-meta span{padding:8px 12px;border-radius:999px;background:#f5f5f7;font-size:12px;color:#333}.config-block{margin:8px 0 14px}.config-block strong{display:block;margin-bottom:8px}.opts.inner{margin-top:0}.opt{margin:4px}.opt.sel{background:#111;color:white;border-color:#111}#features li{margin:8px 0;line-height:1.35}
@media(max-width:760px){.hero-premium{min-height:700px!important;padding:70px 6% 120px!important}.hero-copy h1{font-size:48px;letter-spacing:-2px}.fusion-max{width:720px;right:-330px;top:3%;opacity:.42}.fusion-phone{width:230px;right:-26px;top:33%;opacity:.76}.fusion-airpods{width:150px;right:38%;top:55%;opacity:.68}.fusion-air{width:150px;right:1%;bottom:10%;opacity:.35}.hero-fusion:after{background:linear-gradient(90deg,rgba(3,3,6,.98) 0%,rgba(3,3,6,.84) 62%,rgba(3,3,6,.35) 100%)}.detail #mainImg{height:360px}.detail>div:first-child{padding:8px}}


/* ===== ThinkStore V5: carrito, registro y nota de entrega ===== */
.action-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
.btn.ghost{background:#f5f5f7;color:#111;border:1px solid rgba(0,0,0,.08)}
.register-card,.cart-card,.note-card{max-width:760px;width:min(94vw,760px)}
.customer-form{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.customer-form input,.customer-form select,#payMethod{
  width:100%;padding:14px 16px;border-radius:16px;border:1px solid var(--border);
  background:var(--card);color:var(--text);font-weight:700
}
.customer-form input:nth-child(7),.customer-form input:nth-child(8){grid-column:1/-1}
.cartrow{
  display:grid;grid-template-columns:74px 1fr auto;align-items:center;gap:14px;
  padding:12px;border:1px solid var(--border);border-radius:18px;margin:10px 0;background:rgba(255,255,255,.65)
}
.cartrow img{width:74px;height:74px;object-fit:contain;background:#f5f5f7;border-radius:14px;padding:6px}
.cartrow button{border:0;border-radius:12px;padding:10px 12px;font-weight:900;background:#111;color:#fff}
.cart-actions{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}
.customer-summary{padding:14px;border-radius:18px;background:#f5f5f7;border:1px solid var(--border);margin-bottom:12px}
.delivery-note{background:#fff;color:#111;border-radius:18px;border:1px solid #ddd;padding:18px;max-height:60vh;overflow:auto}
.delivery-note pre{white-space:pre-wrap;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:14px;line-height:1.55}
.muted{color:var(--muted)}
.config-block{width:100%;margin-bottom:12px}
.config-block strong{display:block;margin:8px 0;color:var(--muted)}
.opts.inner{margin-top:8px}
.product-meta{display:flex;gap:8px;flex-wrap:wrap;margin:12px 0}
.product-meta span{padding:8px 10px;background:#f5f5f7;border-radius:999px;border:1px solid var(--border);font-size:13px}
@media(max-width:680px){
  .customer-form{grid-template-columns:1fr}
  .cartrow{grid-template-columns:58px 1fr}
  .cartrow button{grid-column:1/-1}
  .cartrow img{width:58px;height:58px}
}
@media print{
  body>*:not(#noteModal){display:none!important}
  #noteModal{display:block!important;position:static!important;background:#fff!important}
  #noteModal .card{box-shadow:none!important;border:0!important}
  #noteModal .close,#noteModal .action-row{display:none!important}
}

/* ===== ThinkStore Final: menú más llamativo, logos, carrito/admin ===== */
.top{padding:18px 4%!important;background:rgba(255,255,255,.9)!important;box-shadow:0 10px 35px rgba(0,0,0,.08)}
.brand img{width:86px!important;height:86px!important;border:3px solid #fff;box-shadow:0 18px 45px rgba(0,113,227,.28),0 0 0 5px rgba(0,113,227,.08)!important}.brand b{font-size:34px!important;letter-spacing:-1.5px}.brand small{font-size:17px!important}
nav a,nav button{background:linear-gradient(135deg,#fff,#f2f6ff)!important;border:1px solid rgba(0,113,227,.18)!important;box-shadow:0 10px 24px rgba(0,113,227,.1);font-size:16px!important;padding:15px 20px!important}
nav a:hover,nav button:hover{background:linear-gradient(135deg,#0071e3,#7c3cff)!important;color:white!important;transform:translateY(-2px)}
.logos{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin:18px 0}.logos img{height:46px;max-width:110px;object-fit:contain;background:white;border-radius:16px;padding:9px;box-shadow:0 12px 28px rgba(0,0,0,.09);border:1px solid rgba(0,0,0,.08)}.logos.pay img{height:50px;max-width:120px}
.admin-card{max-width:980px;width:min(94vw,980px)}.admin-actions{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}.admin-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}.admin-row{padding:14px;border-radius:18px;border:1px solid var(--border);background:#f7f7fa}.admin-row select{margin:8px 0;padding:9px 12px;border-radius:12px;border:1px solid var(--border)}.form{display:grid;gap:12px}.form input,.form select{padding:14px 16px;border:1px solid var(--border);border-radius:16px;background:var(--card);color:var(--text);font-weight:700}
.prod .photo{height:235px!important;display:flex!important;align-items:center!important;justify-content:center!important;background:radial-gradient(circle at 50% 35%,#fff 0%,#f7f8fb 55%,#eceff5 100%)!important}.prod .photo img{max-height:100%!important;object-fit:contain!important}.detail #mainImg{object-fit:contain!important;background:#f8f8fb;border-radius:24px}
@media(max-width:760px){.brand img{width:64px!important;height:64px!important}.brand b{font-size:28px!important}.top{align-items:flex-start}.prod .photo{height:170px!important}nav a,nav button{font-size:15px!important;padding:13px 17px!important}.hero-copy h1{font-size:43px!important}}


/* ===== ThinkStore V7 - Panel admin, correos y control de pedidos ===== */
.admin-kpis{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
  margin:12px 0 18px;
}
.admin-kpis div{
  border-radius:22px;
  padding:16px;
  background:linear-gradient(135deg,rgba(0,122,255,.12),rgba(122,92,255,.12));
  box-shadow:inset 0 1px 0 rgba(255,255,255,.7);
  text-align:center;
}
.admin-kpis b{
  font-size:30px;
  display:block;
}
.admin-kpis small{
  color:#6e6e73;
  font-weight:800;
}
.admin-row-actions{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  margin-top:10px;
}
.form textarea{
  width:100%;
  border:1px solid rgba(0,0,0,.12);
  border-radius:18px;
  padding:14px;
  font:inherit;
  resize:vertical;
  background:#fff;
}
body.dark .form textarea{
  background:#151518;
  color:#fff;
  border-color:rgba(255,255,255,.16);
}
@media(max-width:720px){
  .admin-kpis{grid-template-columns:1fr;}
}


/* ===== ThinkStore V8 - Nota de entrega premium con QR ===== */
.checkout-extra-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:14px 0}.checkout-extra-grid input,.checkout-extra-grid select{border:1px solid rgba(0,0,0,.12);border-radius:14px;padding:12px;background:#fff;font:inherit}.note-modal-card{width:min(1040px,96vw);max-height:92vh;overflow:auto;background:#f5f5f7;border-radius:28px;padding:18px;position:relative}.premium-note{font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","Helvetica Neue",Arial,sans-serif;color:#1d1d1f}.note-page{background:#fff;border-radius:20px;padding:42px;box-shadow:0 20px 60px rgba(0,0,0,.12)}.note-header{display:grid;grid-template-columns:1fr 1fr;gap:34px;align-items:start;border-bottom:1px solid #d2d2d7;padding-bottom:28px}.note-brand{display:flex;gap:18px;align-items:center}.note-logo{width:74px;height:74px;border-radius:22px;background:#050505;color:#fff;display:grid;place-items:center;font-size:44px}.note-brand h1{margin:0;font-size:34px;letter-spacing:-1px}.note-brand h1 span,.note-footer span{font-weight:400}.note-brand p,.note-title p{color:#6e6e73;margin:8px 0}.note-title{text-align:right}.note-title h2{margin:0 0 12px;font-size:34px;letter-spacing:-.7px}.status-pill{display:inline-block;background:#e8f0ff;color:#174ea6;border-radius:999px;padding:7px 12px;font-size:12px;font-weight:900;text-transform:uppercase}.note-section{margin-top:30px}.note-section h3,.note-box h3{font-size:16px;letter-spacing:-.2px;margin:0 0 14px}.note-grid.two{display:grid;grid-template-columns:1fr 1fr;gap:14px 34px}.note-grid p{display:grid;grid-template-columns:140px 1fr;gap:10px;margin:0;line-height:1.45}.note-table{width:100%;border-collapse:separate;border-spacing:0;border:1px solid #d2d2d7;border-radius:14px;overflow:hidden}.note-table th{background:#f5f5f7;font-size:13px;padding:14px}.note-table td{padding:16px 14px;border-top:1px solid #e5e5ea;text-align:center}.note-table td:first-child{text-align:left}.note-table small{display:block;color:#6e6e73;margin-top:4px}.note-table tfoot td{font-weight:900;background:#fbfbfd}.note-cards{margin-top:28px}.note-box{border:1px solid #d2d2d7;border-radius:18px;padding:18px;background:#fff}.note-box p{display:flex;justify-content:space-between;gap:14px;border-bottom:1px solid #f1f1f3;padding-bottom:10px}.pay-icons,.shipping-icons{display:flex;flex-wrap:wrap;gap:9px;margin-top:14px}.pay-icons span,.pay-badge,.ship-logo{display:inline-flex;align-items:center;justify-content:center;min-height:28px;padding:6px 10px;border-radius:9px;font-size:12px;font-weight:900;background:#f5f5f7}.pay-badge.pago{background:#e9f8ee;color:#14823b}.pay-badge.zelle{background:#f0e9ff;color:#6d35d6}.pay-badge.binance{background:#fff6d8;color:#a06a00}.pay-badge.bank{background:#eef4ff;color:#1b4f9c}.pay-badge.card{background:#eaf0ff;color:#0b57d0}.pay-badge.cash{background:#f2f2f2;color:#333}.ship-logo.mrw{background:#eef2ff;color:#153e90}.ship-logo.zoom{background:#eef7ff;color:#0b63b6}.ship-logo.tealca{background:#e9f6ff;color:#0076a8}.ship-logo.store{background:#f5f5f7;color:#111}.note-timeline{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;align-items:start;margin-top:22px}.note-step{text-align:center;position:relative}.note-step:not(:last-child)::after{content:"";position:absolute;top:19px;left:58%;width:84%;height:2px;background:#d2d2d7}.note-step.active:not(:last-child)::after{background:#1d1d1f}.note-dot{width:40px;height:40px;border-radius:50%;margin:0 auto 10px;background:#fff;border:2px solid #d2d2d7;display:grid;place-items:center;font-weight:900;position:relative;z-index:1}.note-step.active .note-dot{background:#050505;color:#fff;border-color:#050505}.note-step span{display:block;font-weight:800;font-size:13px}.note-step small{display:block;color:#6e6e73;margin-top:5px;font-size:12px}.note-footer-grid{display:grid;grid-template-columns:1fr 260px;gap:30px;margin-top:30px;align-items:center}.note-observations{background:#f5f5f7;border-radius:14px;padding:18px}.note-observations p{margin-bottom:0}.note-qr-wrap{display:grid;grid-template-columns:96px 1fr;gap:14px;align-items:center}.note-qr-wrap p{margin:0;color:#6e6e73}.note-footer{margin-top:26px;padding-top:18px;border-top:1px solid #d2d2d7;display:flex;justify-content:space-between;gap:16px;color:#6e6e73}.note-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;padding:16px 0 4px}@media(max-width:760px){.checkout-extra-grid,.note-header,.note-grid.two,.note-footer-grid{grid-template-columns:1fr}.note-page{padding:24px}.note-title{text-align:left}.note-grid p{grid-template-columns:1fr}.note-timeline{grid-template-columns:1fr;gap:18px}.note-step:not(:last-child)::after{display:none}.note-footer{flex-direction:column}.note-table{font-size:12px}.note-table th,.note-table td{padding:10px 8px}}@media print{body *{visibility:hidden!important}#premiumNote,#premiumNote *{visibility:visible!important}#premiumNote{position:absolute;left:0;top:0;width:100%}.note-actions,.close{display:none!important}.note-page{box-shadow:none;border-radius:0}}

.note-logo img{width:100%;height:100%;object-fit:cover;border-radius:22px;display:block;}


/* ===== ThinkStore V9 login cliente + nota de entrega exacta ===== */
.auth-tabs{display:flex;gap:10px;margin:14px 0 18px}.auth-tabs .opt{flex:1}.account-card{width:min(820px,94vw)}.account-head{display:flex;gap:14px;align-items:center;margin-bottom:18px}.account-head img{width:62px;height:62px;object-fit:cover;border-radius:18px;background:#111}.account-box{background:#f5f5f7;border-radius:22px;padding:18px}.apple-note{font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","Helvetica Neue",Arial,sans-serif;color:#1d1d1f;background:#fff;border-radius:0;box-shadow:0 20px 70px rgba(0,0,0,.14);padding:50px 56px;max-width:980px;margin:auto}.apple-note-header{display:grid;grid-template-columns:1fr 1px 1fr;align-items:start;gap:46px;border-bottom:0;padding-bottom:34px}.note-divider{width:1px;height:120px;background:#c9c9ce}.apple-note-brand{display:flex;gap:22px;align-items:center}.apple-note-logo{width:78px;height:78px;border-radius:0;background:transparent;overflow:hidden}.apple-note-logo img{width:100%;height:100%;object-fit:contain}.apple-note-brand h1{font-size:38px;letter-spacing:-1.5px;margin:0;font-weight:900}.apple-note-brand h1 span{font-weight:400}.apple-note-brand p{font-size:16px;color:#6e6e73;margin-top:12px}.apple-note-title{text-align:left}.apple-note-title h2{font-size:36px;letter-spacing:-1px;margin:0 0 18px;font-weight:900}.apple-note-title p{font-size:16px;margin:12px 0;color:#444}.status-pill{background:#e9f1ff;color:#1455c8;border-radius:999px;padding:7px 15px;font-size:12px;font-weight:900;text-transform:uppercase}.apple-section{margin-top:28px}.apple-section h3,.apple-box h3{font-size:16px;border-bottom:1px solid #d2d2d7;padding-bottom:10px;margin-bottom:18px;font-weight:900}.line-icon{display:inline-flex;margin-right:8px;color:#111}.apple-client-grid{gap:22px 56px}.apple-client-grid p{display:grid;grid-template-columns:130px 1fr;font-size:15px;line-height:1.45}.apple-table{border:1px solid #d2d2d7;border-radius:10px;overflow:hidden;border-collapse:separate;border-spacing:0;width:100%;font-size:14px}.apple-table th{background:#f5f5f7;padding:14px;text-align:center;font-weight:900}.apple-table td{border-top:1px solid #e5e5ea;padding:14px;text-align:center}.product-cell{display:flex;gap:14px;align-items:center;text-align:left!important}.product-cell img{width:54px;height:54px;object-fit:contain;border-radius:8px;background:#f5f5f7}.product-cell small{display:block;color:#6e6e73;margin-top:3px}.apple-table tfoot td{font-weight:900;background:#fbfbfd}.apple-table tfoot td:first-child{text-align:right}.apple-cards{margin-top:32px;gap:28px}.apple-box{border:1px solid #d2d2d7;border-radius:12px;background:#fff;padding:16px 18px}.apple-box p{display:grid;grid-template-columns:140px 1fr;gap:12px;margin:12px 0;font-size:14px;border-bottom:0}.pay-badge,.pay-icons span,.ship-logo{display:inline-flex;align-items:center;justify-content:center;border-radius:8px;padding:7px 10px;font-size:12px;font-weight:900;background:#f5f5f7}.pay-badge.pago{background:#eaf3ff;color:#0a58ca}.pay-badge.zelle{background:#f0e9ff;color:#6d35d6}.pay-badge.binance{background:#fff7da;color:#a66a00}.pay-badge.bank{background:#edf4ff;color:#174ea6}.pay-badge.cash{background:#f3f3f3;color:#333}.pay-icons,.shipping-icons{display:flex;flex-wrap:wrap;gap:10px;border-top:1px solid #e5e5ea;margin-top:18px;padding-top:16px}.ship-logo.mrw{font-size:20px;color:#173d8f;background:#fff;font-style:italic}.ship-logo.zoom{font-size:20px;color:#174ea6;background:#fff}.ship-logo.tealca{font-size:20px;color:#0076a8;background:#fff}.ship-logo.store{background:#111;color:#fff}.apple-timeline{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:25px}.note-step{text-align:center;position:relative}.note-step:not(:last-child)::after{content:"";position:absolute;top:21px;left:50%;width:100%;height:2px;background:#d2d2d7;z-index:0}.note-step.active:not(:last-child)::after{background:#111}.note-dot{width:44px;height:44px;border-radius:50%;border:2px solid #bfc0c5;background:#fff;margin:0 auto 10px;display:grid;place-items:center;font-weight:900;position:relative;z-index:1}.note-step.active .note-dot{background:#050505;color:#fff;border-color:#050505}.note-step span{display:block;font-size:13px;font-weight:900}.note-step small{display:block;color:#6e6e73;font-size:12px;margin-top:7px}.apple-note-bottom{display:grid;grid-template-columns:1fr 340px;gap:32px;align-items:center;margin-top:30px}.apple-observations{background:#f5f5f7;border-radius:12px;padding:18px;font-size:13px}.apple-observations p{margin-bottom:0}.apple-qr-wrap{display:grid;grid-template-columns:100px 1fr;gap:16px;align-items:center}.apple-qr-wrap p{margin:0 0 8px;color:#444;font-size:13px}.apple-qr-wrap b{font-size:13px;color:#0066cc}.apple-note-footer{border-top:1px solid #d2d2d7;margin-top:25px;padding-top:20px;display:flex;gap:20px;justify-content:space-between;align-items:center;color:#444;font-size:14px}.apple-note-footer img{width:34px;height:34px;object-fit:contain;margin-right:8px;vertical-align:middle}.apple-note-footer b{font-size:20px;color:#111}.note-modal-card{width:min(1080px,96vw);max-height:94vh;overflow:auto;background:#f5f5f7;border-radius:28px;padding:18px}.note-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin:18px 0}.checkout-extra-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0}.checkout-extra-grid input,.checkout-extra-grid select{width:100%;border:1px solid rgba(0,0,0,.12);border-radius:14px;padding:12px;background:#fff;font:inherit}@media(max-width:760px){.apple-note{padding:26px 18px}.apple-note-header,.apple-client-grid,.apple-cards,.apple-note-bottom{grid-template-columns:1fr}.note-divider{display:none}.apple-note-title{text-align:left}.apple-timeline{grid-template-columns:1fr;gap:16px}.note-step:not(:last-child)::after{display:none}.apple-note-footer{flex-direction:column;align-items:flex-start}.apple-table{font-size:12px}.product-cell{flex-direction:column}.apple-box p,.apple-client-grid p{grid-template-columns:1fr}.checkout-extra-grid{grid-template-columns:1fr}}@media print{body *{visibility:hidden!important}#premiumNote,#premiumNote *{visibility:visible!important}#premiumNote{position:absolute;left:0;top:0;width:100%}.note-actions,.close{display:none!important}.apple-note{box-shadow:none}.note-modal-card{padding:0;background:#fff}}


/* ===== ThinkStore V9.1 - Nota de entrega A4 exacta ===== */
#premiumNoteModal.open,
#noteModal.open{
  display:flex!important;
  align-items:flex-start!important;
  justify-content:center!important;
  overflow:auto!important;
  padding:24px 10px!important;
}
.note-modal-card,
#premiumNoteModal .card,
#noteModal .card{
  width:min(1040px,96vw)!important;
  max-height:none!important;
  overflow:visible!important;
  border-radius:28px!important;
  background:#f5f5f7!important;
  padding:16px!important;
}
#premiumNote,
#noteContent{
  width:100%!important;
  overflow:auto!important;
  -webkit-overflow-scrolling:touch!important;
}
.ts-note-sheet{
  width:960px;
  min-height:1240px;
  margin:0 auto;
  background:#fff;
  color:#1d1d1f;
  font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text","Helvetica Neue",Arial,sans-serif;
  padding:48px;
  box-sizing:border-box;
  border-radius:0;
  box-shadow:0 18px 60px rgba(0,0,0,.12);
  font-size:14px;
  line-height:1.35;
}
.ts-note-header{
  display:grid;
  grid-template-columns:380px 1px 1fr;
  gap:42px;
  align-items:start;
  margin-bottom:52px;
}
.ts-note-brand{
  display:flex;
  align-items:center;
  gap:22px;
}
.ts-logo-box{
  width:82px;
  height:82px;
  border-radius:20px;
  background:#050505;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}
.ts-logo-box img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.ts-logo-box.fallback-logo::before{
  content:"T";
  color:#fff;
  font-size:42px;
  font-weight:900;
}
.ts-note-brand h1{
  margin:0;
  font-size:34px;
  letter-spacing:-1.5px;
  font-weight:900;
}
.ts-note-brand h1 span{
  font-weight:400;
}
.ts-note-brand p{
  margin:12px 0 0;
  color:#6e6e73;
  font-size:18px;
}
.ts-note-separator{
  width:1px;
  height:115px;
  background:#d2d2d7;
}
.ts-note-title{
  text-align:center;
}
.ts-note-title h2{
  margin:0 0 18px;
  font-size:34px;
  letter-spacing:-1px;
  font-weight:900;
}
.ts-note-title p{
  margin:9px 0;
  display:flex;
  gap:18px;
  justify-content:center;
  color:#3a3a3c;
  font-size:15px;
}
.ts-note-title p span{
  min-width:58px;
  text-align:right;
}
.ts-note-title strong{
  background:#e8f0ff;
  color:#174ea6;
  padding:6px 15px;
  border-radius:999px;
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}
.ts-section{
  margin-top:26px;
}
.ts-section h3,
.ts-info-card h3{
  font-size:16px;
  font-weight:900;
  margin:0 0 12px;
  display:flex;
  align-items:center;
  gap:10px;
}
.ts-section h3 span,
.ts-info-card h3 span{
  font-weight:400;
  font-size:21px;
}
.ts-client-grid{
  border-top:1px solid #d2d2d7;
  padding-top:20px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px 70px;
}
.ts-client-grid div{
  display:grid;
  grid-template-columns:120px 1fr;
  gap:18px;
}
.ts-client-grid b{
  font-weight:900;
}
.ts-client-grid p{
  margin:0;
  color:#1d1d1f;
}
.ts-products-table{
  width:100%;
  border-collapse:separate;
  border-spacing:0;
  border:1px solid #d2d2d7;
  border-radius:9px;
  overflow:hidden;
  table-layout:fixed;
}
.ts-products-table th{
  padding:13px 10px;
  background:linear-gradient(#fbfbfd,#f5f5f7);
  font-weight:900;
  font-size:13px;
  text-align:center;
}
.ts-products-table td{
  padding:14px 10px;
  border-top:1px solid #e5e5ea;
  border-left:1px solid #e5e5ea;
  text-align:center;
  vertical-align:middle;
  font-size:14px;
}
.ts-products-table td:first-child,
.ts-products-table th:first-child{
  border-left:none;
}
.ts-products-table tfoot td{
  background:#fbfbfd;
  font-weight:900;
}
.ts-products-table tfoot td:first-child{
  text-align:right;
}
.ts-product-cell{
  display:flex;
  align-items:center;
  gap:13px;
  text-align:left!important;
}
.ts-product-cell img,
.ts-prod-placeholder{
  width:52px;
  height:52px;
  border-radius:8px;
  object-fit:contain;
  background:#f5f5f7;
  flex:0 0 52px;
}
.ts-info-grid{
  display:grid;
  grid-template-columns:1fr 1.12fr;
  gap:28px;
  margin-top:34px;
}
.ts-info-card{
  border:1px solid #d2d2d7;
  border-radius:9px;
  overflow:hidden;
  background:#fff;
}
.ts-info-card h3{
  padding:0;
  margin:0 0 12px;
}
.ts-info-card > h3{
  border:none;
  padding:0;
  margin:0;
  position:absolute;
  transform:translateY(-31px);
}
.ts-info-row{
  display:grid;
  grid-template-columns:140px 1fr;
  gap:10px;
  padding:8px 14px;
}
.ts-info-row:first-of-type{
  padding-top:18px;
}
.ts-info-row b{
  font-weight:700;
  color:#1d1d1f;
}
.ts-info-row p{
  margin:0;
}
.ts-pay-strip,
.ts-ship-strip{
  display:flex;
  align-items:center;
  gap:18px;
  flex-wrap:wrap;
  border-top:1px solid #e5e5ea;
  padding:18px;
  min-height:64px;
}
.ts-pay-strip span,
.ts-ship-logo{
  font-weight:900;
  line-height:1;
}
.ts-pago{
  color:#17975b;
  font-size:10px;
}
.ts-zelle-text{color:#6d35d6;font-size:21px;}
.ts-binance-text{color:#f3a000;}
.ts-visa{color:#163c86;font-size:20px;font-style:italic;}
.ts-master{
  position:relative;
  width:42px;
  height:24px;
  display:inline-block;
}
.ts-master i{
  position:absolute;
  width:24px;
  height:24px;
  border-radius:50%;
}
.ts-master i:first-child{background:#eb001b;left:0;}
.ts-master i:last-child{background:#f79e1b;right:0;opacity:.9;}
.ts-transfer{
  flex-basis:100%;
  color:#333;
  font-weight:500!important;
}
.ts-pay-mini{
  display:inline-flex;
  min-width:24px;
  min-height:24px;
  align-items:center;
  justify-content:center;
  border-radius:6px;
  margin-right:6px;
  font-size:10px;
  color:#fff;
  background:#0b57d0;
}
.ts-zelle{background:#6d35d6;}
.ts-binance{background:#f3a000;}
.ts-bank{background:#2f80ed;}
.ts-card{background:#163c86;}
.ts-cash{background:#1d1d1f;}
.ts-ship-logo{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:70px;
  min-height:28px;
  border-radius:4px;
  letter-spacing:-1px;
}
.ts-mrw{color:#173b85;font-size:24px;font-style:italic;}
.ts-zoom{color:#0b4c9c;font-size:21px;}
.ts-tealca{color:#0288c9;font-size:19px;}
.ts-store{background:#f5f5f7;color:#1d1d1f;padding:0 8px;letter-spacing:0;font-size:12px;}
.ts-status-section{
  margin-top:38px;
}
.ts-timeline{
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:0;
  position:relative;
  margin-top:16px;
}
.ts-timeline::before{
  content:"";
  position:absolute;
  top:21px;
  left:60px;
  right:60px;
  height:2px;
  background:linear-gradient(90deg,#1d1d1f 0 50%, #d2d2d7 50% 100%);
  z-index:0;
}
.ts-step{
  text-align:center;
  position:relative;
  z-index:1;
}
.ts-step-dot{
  width:42px;
  height:42px;
  border-radius:50%;
  border:2px solid #d2d2d7;
  background:#fff;
  color:#fff;
  display:grid;
  place-items:center;
  margin:0 auto 12px;
  font-weight:900;
}
.ts-step.active .ts-step-dot{
  background:#050505;
  border-color:#050505;
}
.ts-step b{
  display:block;
  font-size:12px;
  margin-bottom:6px;
}
.ts-step span{
  display:block;
  font-size:12px;
  color:#6e6e73;
}
.ts-bottom-grid{
  display:grid;
  grid-template-columns:1fr 310px;
  gap:34px;
  align-items:center;
  margin-top:30px;
}
.ts-observations{
  background:#f5f5f7;
  border-radius:8px;
  padding:15px;
  min-height:58px;
}
.ts-observations b{
  font-size:12px;
}
.ts-observations p{
  margin:11px 0 0;
  font-size:13px;
}
.ts-qr-area{
  display:grid;
  grid-template-columns:82px 1fr;
  gap:15px;
  align-items:center;
}
.ts-qr-area p{
  margin:0 0 6px;
  font-size:13px;
}
.ts-qr-area a{
  color:#0066cc;
  font-size:13px;
}
.ts-note-footer{
  margin-top:22px;
  border-top:1px solid #d2d2d7;
  padding-top:22px;
  display:grid;
  grid-template-columns:1.2fr 1.2fr 1fr 1.2fr;
  gap:12px;
  align-items:center;
  color:#3a3a3c;
}
.ts-footer-brand{
  display:flex;
  align-items:center;
  gap:10px;
}
.ts-footer-brand img{
  width:38px;
  height:38px;
  object-fit:cover;
  border-radius:10px;
}
.ts-footer-brand b{
  font-size:20px;
}
.ts-footer-brand span{
  font-weight:400;
}
.ts-note-footer p{
  margin:0;
  font-size:13px;
}
.ts-final-note{
  text-align:center;
  color:#6e6e73;
  margin:12px 0 0;
  font-size:13px;
}
@media(max-width:760px){
  #premiumNote,#noteContent{
    overflow-x:auto!important;
  }
  .ts-note-sheet{
    transform-origin:top left;
    width:960px;
    max-width:none;
    padding:48px;
  }
}
@media print{
  body *{visibility:hidden!important;}
  #premiumNote,#premiumNote *,#noteContent,#noteContent *{visibility:visible!important;}
  #premiumNote,#noteContent{position:absolute!important;left:0!important;top:0!important;width:100%!important;overflow:visible!important;}
  .ts-note-sheet{width:100%!important;box-shadow:none!important;margin:0!important;}
  .note-actions,.close{display:none!important;}
}


/* ===== ThinkStore V10 - Panel administrador completo ===== */
.admin-floating{position:fixed;left:18px;bottom:18px;z-index:99;border:0;background:#111;color:#fff;border-radius:999px;padding:12px 18px;font-weight:900;box-shadow:0 18px 45px rgba(0,0,0,.22)}
.admin-suite-modal.open{display:flex!important;align-items:center;justify-content:center;padding:16px}
.admin-suite{width:min(1280px,98vw);height:min(840px,94vh);background:#f5f5f7;border-radius:30px;overflow:hidden;display:grid;grid-template-columns:260px 1fr;box-shadow:0 28px 90px rgba(0,0,0,.28);position:relative}
.admin-close{position:absolute!important;right:18px!important;top:18px!important;z-index:5}
.admin-sidebar{background:#101014;color:#fff;padding:22px;overflow:auto}
.admin-brand{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.admin-brand img{width:54px;height:54px;border-radius:16px;object-fit:cover}
.admin-brand b{display:block;font-size:20px}.admin-brand small{color:#a1a1aa}
.admin-tab{width:100%;border:0;background:transparent;color:#c7c7d1;padding:13px 14px;text-align:left;border-radius:16px;font-weight:850;cursor:pointer;margin-bottom:6px}
.admin-tab.active,.admin-tab:hover{background:#fff;color:#111}
.admin-main{overflow:auto;padding:32px}
.admin-view{display:none}.admin-view.active{display:block}
.admin-header{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:22px}
.admin-header h2{font-size:38px;letter-spacing:-.04em;margin:0}.admin-header p{margin:6px 0 0;color:#6e6e73}
.admin-kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:22px}
.admin-kpi-grid div,.admin-card{background:#fff;border-radius:24px;padding:20px;box-shadow:0 14px 40px rgba(0,0,0,.06)}
.admin-kpi-grid span,.admin-kpi-grid small{color:#6e6e73;font-weight:800}.admin-kpi-grid b{display:block;font-size:34px;margin:8px 0}
.admin-two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px}.admin-card h3{margin-top:0}
.mini-row{display:flex;justify-content:space-between;gap:12px;padding:12px 0;border-bottom:1px solid #eee}.mini-row span{color:#6e6e73}
.admin-toolbar{display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap}
.admin-toolbar input,.admin-toolbar select,.admin-table input,.admin-table select,.settings-grid input,.settings-grid textarea,.admin-form-grid input,.admin-form-grid select,.admin-form-grid textarea,.admin-order-card input,.admin-order-card select{border:1px solid #ddd;background:#fff;border-radius:14px;padding:11px 13px;font:inherit}
.admin-toolbar input{flex:1;min-width:220px}
.admin-table-wrap{background:#fff;border-radius:24px;overflow:auto;box-shadow:0 14px 40px rgba(0,0,0,.06)}
.admin-table{width:100%;border-collapse:collapse;min-width:760px}
.admin-table th{background:#fbfbfd;color:#6e6e73;text-align:left;padding:14px;font-size:12px;text-transform:uppercase}
.admin-table td{padding:14px;border-top:1px solid #eee;vertical-align:middle}.admin-table small{display:block;color:#6e6e73;margin-top:5px}
.admin-table button,.admin-order-card button{border:0;background:#111;color:#fff;border-radius:12px;padding:9px 12px;font-weight:850;margin:3px}
#adminOrdersList.admin-list{display:flex;flex-direction:column;gap:10px;overflow:auto;max-height:calc(92vh - 250px);padding-right:6px}
.admin-order-card{background:#fff;border-radius:20px;padding:13px 14px;margin-bottom:0;display:grid;grid-template-columns:minmax(115px,.75fr) minmax(190px,1.25fr) minmax(210px,1.4fr) minmax(170px,1fr) minmax(170px,.95fr);gap:12px;align-items:center;box-shadow:0 8px 24px rgba(0,0,0,.055);border:1px solid rgba(0,0,0,.045);width:100%;box-sizing:border-box}
.admin-order-card b{font-size:14px;line-height:1.15}.admin-order-card small{display:block;color:#6e6e73;margin-top:4px;font-size:12px;line-height:1.25}.admin-order-card .order-code{font-size:16px;letter-spacing:-.02em}.admin-order-items{font-size:12px;line-height:1.25;color:#424245}.admin-order-items b{display:block;margin-bottom:3px}.admin-order-card select{width:100%;min-width:0}.admin-row-actions{display:grid;grid-template-columns:1fr 1fr;gap:6px}.admin-row-actions button{width:100%;white-space:nowrap}.admin-order-badge{display:inline-flex;align-items:center;gap:5px;border-radius:999px;padding:5px 8px;background:#f4f4f6;color:#1d1d1f;font-weight:850;font-size:11px;margin-top:5px}.admin-order-head{display:grid;grid-template-columns:minmax(115px,.75fr) minmax(190px,1.25fr) minmax(210px,1.4fr) minmax(170px,1fr) minmax(170px,.95fr);gap:12px;padding:0 14px 8px;color:#86868b;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.05em}.admin-order-empty{padding:28px;border-radius:22px;background:#fff;text-align:center;color:#6e6e73}
@media(max-width:1100px){.admin-order-head{display:none}.admin-order-card{grid-template-columns:1fr 1fr}.admin-row-actions{grid-column:1/-1;grid-template-columns:1fr 1fr}.admin-order-card select{max-width:100%}}
@media(max-width:680px){.admin-order-card{grid-template-columns:1fr}.admin-row-actions{grid-template-columns:1fr}.admin-toolbar{grid-template-columns:1fr!important}}
.status-chip{display:inline-block;background:#e8f0ff;color:#174ea6;border-radius:999px;padding:7px 10px;font-weight:900;font-size:12px}
.settings-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.settings-grid label{display:block;font-weight:850;margin:10px 0 6px}.settings-grid input,.settings-grid textarea{width:100%}
.admin-product-card{max-width:860px!important}.admin-form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.admin-form-grid textarea{grid-column:1/-1}
@media(max-width:900px){.admin-suite{grid-template-columns:1fr;height:94vh}.admin-sidebar{display:flex;overflow:auto;gap:8px;padding:14px}.admin-brand{display:none}.admin-tab{white-space:nowrap;margin:0}.admin-main{padding:20px}.admin-kpi-grid,.admin-two-col,.settings-grid{grid-template-columns:1fr}.admin-order-card{grid-template-columns:1fr}.admin-form-grid{grid-template-columns:1fr}}


/* ===== ThinkStore V11 - correcciones públicas y móvil ===== */
.top nav button[onclick="openAdminSuite()"], .admin-floating { display:none!important; }
.hero-copy .btn { margin-right:10px; margin-top:10px; }
.float{right:18px;bottom:18px;z-index:80;min-width:128px;text-align:center;white-space:nowrap;}
@media(max-width:760px){
  body{overflow-x:hidden;}
  .top{align-items:flex-start;gap:10px;padding:10px 12px;}
  .brand{min-width:190px;}
  .brand img{width:54px;height:54px;}
  .brand span b{font-size:24px;line-height:1;}
  .brand span small{font-size:14px;line-height:1.15;display:block;max-width:170px;}
  .top nav{display:flex;overflow-x:auto;gap:8px;padding-bottom:6px;width:100%;scrollbar-width:none;}
  .top nav::-webkit-scrollbar{display:none;}
  .top nav a,.top nav button{flex:0 0 auto;min-height:42px;border-radius:999px;padding:9px 13px;font-size:14px;}
  .hero-premium{min-height:690px;padding:120px 18px 34px;overflow:hidden;}
  .hero-copy{max-width:100%;position:relative;z-index:2;}
  .hero-copy h1{font-size:46px;line-height:.98;letter-spacing:-2px;max-width:95%;}
  .hero-copy p:not(.eyebrow){font-size:18px;line-height:1.32;max-width:92%;}
  .hero-copy .btn{display:inline-flex;align-items:center;justify-content:center;min-width:142px;margin:8px 6px 0 0;padding:13px 16px;white-space:nowrap;}
  .hero-copy .btn.wa{min-width:132px;}
  .fusion-phone{right:-36px!important;max-width:190px!important;top:230px!important;}
  .fusion-airpods{right:26px!important;top:180px!important;max-width:130px!important;}
  .fusion-air{right:-72px!important;bottom:115px!important;max-width:170px!important;opacity:.85;}
  .cats{display:flex;overflow-x:auto;gap:10px;padding:14px 12px;scrollbar-width:none;}
  .cats::-webkit-scrollbar{display:none;}
  .cats a{flex:0 0 auto;min-width:132px;}
  .float{right:12px;bottom:12px;min-width:112px;padding:12px 18px;font-size:14px;}
  .action-row{display:grid;grid-template-columns:1fr;gap:10px;}
}
@media(min-width:761px){.hero-copy .btn{vertical-align:middle;}}

/* ThinkStore category modal polish */
.cats button{border:0;background:rgba(255,255,255,.86);border-radius:28px;padding:18px 22px;min-width:150px;display:flex;align-items:center;justify-content:center;gap:10px;font:inherit;font-weight:900;color:#1d1d1f;box-shadow:0 16px 45px rgba(0,0,0,.10);cursor:pointer;transition:transform .2s ease, box-shadow .2s ease, background .2s ease}
.cats button:hover{transform:translateY(-4px);box-shadow:0 24px 55px rgba(0,0,0,.16);background:#fff}
.category-modal.open{display:flex!important;align-items:center;justify-content:center;padding:18px;z-index:9999}
.category-card{width:min(1180px,96vw);max-height:92vh;overflow:auto;border-radius:32px;padding:26px;background:rgba(255,255,255,.96);backdrop-filter:blur(18px)}
.category-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18px;margin-bottom:22px;border-bottom:1px solid rgba(0,0,0,.08);padding-bottom:18px}
.category-head h2{font-size:clamp(30px,5vw,54px);letter-spacing:-1.8px;margin:2px 0 8px}.category-grid{padding:4px 2px 10px}.category-grid .prod{min-height:100%;cursor:pointer}.category-grid .photo{background:linear-gradient(180deg,#f7f7f8,#fff)}
@media(max-width:760px){.cats{gap:10px}.cats button{min-width:calc(50% - 8px);padding:14px 12px}.category-card{padding:20px;border-radius:24px}.category-head{display:block}.category-head .btn{margin-top:12px;width:100%}}


/* ===== ThinkStore V2 Premium Visual Layer ===== */
.ts-v2-hero{
  position:relative;
  min-height:680px;
  overflow:hidden;
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:center;
  gap:24px;
  padding:110px max(24px,6vw) 70px;
  background:
    radial-gradient(circle at 72% 32%, rgba(0,113,227,.28), transparent 28%),
    radial-gradient(circle at 82% 72%, rgba(165,120,255,.18), transparent 26%),
    linear-gradient(135deg,#050507 0%,#111116 46%,#1d1d1f 100%);
  color:#fff;
  isolation:isolate;
}
.ts-v2-hero-bg{
  position:absolute;
  inset:0;
  background:
    linear-gradient(90deg, rgba(0,0,0,.78) 0%, rgba(0,0,0,.35) 48%, rgba(0,0,0,.08) 100%),
    radial-gradient(circle at 20% 20%, rgba(255,255,255,.10), transparent 20%);
  z-index:-1;
}
.ts-v2-kicker{
  display:inline-block;
  padding:8px 14px;
  border-radius:999px;
  background:rgba(255,255,255,.11);
  border:1px solid rgba(255,255,255,.18);
  color:#f5f5f7;
  font-weight:800;
  margin-bottom:18px;
}
.ts-v2-hero h1{
  font-size:clamp(48px,7vw,92px);
  line-height:.92;
  letter-spacing:-.07em;
  margin:0 0 20px;
}
.ts-v2-hero p{
  max-width:580px;
  color:#d2d2d7;
  font-size:clamp(18px,2vw,24px);
  line-height:1.35;
  margin:0 0 28px;
}
.ts-v2-hero-actions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
}
.ts-v2-hero .btn{
  min-height:48px;
  border-radius:999px;
  padding:0 24px;
  font-weight:900;
}
.ts-v2-primary{
  background:#0071e3!important;
  color:#fff!important;
  border:0!important;
}
.ts-v2-secondary{
  background:rgba(255,255,255,.10)!important;
  color:#fff!important;
  border:1px solid rgba(255,255,255,.20)!important;
  backdrop-filter:blur(12px);
}
.ts-v2-hero-device{
  position:relative;
  display:grid;
  place-items:center;
  min-height:460px;
}
.ts-v2-device-glow{
  position:absolute;
  width:78%;
  aspect-ratio:1;
  border-radius:50%;
  background:radial-gradient(circle,rgba(0,113,227,.30),rgba(255,255,255,.10),transparent 65%);
  filter:blur(4px);
}
.ts-v2-hero-device img{
  position:relative;
  max-width:min(520px,95%);
  max-height:520px;
  object-fit:contain;
  filter:drop-shadow(0 36px 55px rgba(0,0,0,.48));
  transform:translateY(10px);
}
.ts-v2-categories,
.ts-v2-featured{
  padding:70px max(18px,5vw);
  background:#f5f5f7;
}
.ts-v2-section-head{
  text-align:center;
  max-width:780px;
  margin:0 auto 34px;
}
.ts-v2-section-head h2{
  font-size:clamp(34px,5vw,62px);
  margin:0 0 10px;
  letter-spacing:-.055em;
  color:#1d1d1f;
}
.ts-v2-section-head p{
  color:#6e6e73;
  font-size:18px;
  margin:0;
}
.ts-v2-category-grid{
  display:grid;
  grid-template-columns:repeat(6,minmax(140px,1fr));
  gap:16px;
}
.ts-v2-category-card{
  border:0;
  min-height:230px;
  border-radius:30px;
  padding:22px;
  text-align:left;
  cursor:pointer;
  overflow:hidden;
  position:relative;
  background:#fff;
  color:#1d1d1f;
  box-shadow:0 16px 40px rgba(0,0,0,.07);
  transition:transform .22s ease, box-shadow .22s ease;
}
.ts-v2-category-card:hover{
  transform:translateY(-6px);
  box-shadow:0 22px 55px rgba(0,0,0,.11);
}
.ts-v2-category-card span{
  display:inline-flex;
  padding:7px 11px;
  border-radius:999px;
  background:rgba(255,255,255,.64);
  font-weight:900;
  font-size:12px;
  color:#1d1d1f;
  backdrop-filter:blur(12px);
}
.ts-v2-category-card h3{
  position:relative;
  z-index:1;
  font-size:28px;
  letter-spacing:-.04em;
  margin:58px 0 6px;
}
.ts-v2-category-card p{
  position:relative;
  z-index:1;
  margin:0;
  color:#6e6e73;
  font-weight:700;
}
.ts-v2-category-card::after{
  content:"";
  position:absolute;
  right:-20px;
  bottom:-28px;
  width:150px;
  height:150px;
  border-radius:42px;
  transform:rotate(-18deg);
  opacity:.92;
  background:linear-gradient(135deg,#fff,rgba(255,255,255,.2));
  box-shadow:inset 0 0 0 1px rgba(255,255,255,.3);
}
.ts-v2-category-card.iphone{background:linear-gradient(135deg,#eaf2ff,#ffffff);}
.ts-v2-category-card.mac{background:linear-gradient(135deg,#f3f0ff,#ffffff);}
.ts-v2-category-card.ipad{background:linear-gradient(135deg,#fff3e8,#ffffff);}
.ts-v2-category-card.airpods{background:linear-gradient(135deg,#eafaf2,#ffffff);}
.ts-v2-category-card.watch{background:linear-gradient(135deg,#fff0f4,#ffffff);}
.ts-v2-category-card.accesorios{background:linear-gradient(135deg,#f1f1f3,#ffffff);}
.ts-v2-featured-grid,
.ts-v2-category-products{
  display:grid;
  grid-template-columns:repeat(4,minmax(220px,1fr));
  gap:18px;
}
.ts-v2-product-card{
  background:#fff;
  border-radius:30px;
  overflow:hidden;
  box-shadow:0 16px 45px rgba(0,0,0,.07);
  display:flex;
  flex-direction:column;
}
.ts-v2-product-img{
  min-height:230px;
  display:grid;
  place-items:center;
  background:linear-gradient(180deg,#fbfbfd,#f5f5f7);
  padding:22px;
}
.ts-v2-product-img img{
  width:100%;
  height:210px;
  object-fit:contain;
}
.ts-v2-product-body{
  padding:22px;
}
.ts-v2-product-body span{
  color:#0071e3;
  font-weight:900;
  font-size:12px;
  text-transform:uppercase;
}
.ts-v2-product-body h3{
  font-size:24px;
  letter-spacing:-.035em;
  margin:8px 0;
}
.ts-v2-product-body p{
  color:#6e6e73;
  margin:0 0 12px;
  min-height:42px;
}
.ts-v2-product-body b{
  display:block;
  margin-bottom:16px;
}
.ts-v2-card-actions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}
.ts-v2-card-actions .btn{
  border-radius:999px;
  padding:10px 16px;
}
.ts-v2-category-modal.open{
  display:flex!important;
  align-items:center;
  justify-content:center;
  padding:18px;
}
.ts-v2-category-window{
  width:min(1180px,96vw);
  max-height:90vh;
  overflow:auto;
  background:#f5f5f7;
  border-radius:34px;
  padding:28px;
  position:relative;
  box-shadow:0 28px 90px rgba(0,0,0,.24);
}
.ts-v2-close{
  position:sticky!important;
  float:right;
  top:0;
  z-index:5;
}
.ts-v2-category-window-head{
  text-align:center;
  max-width:720px;
  margin:10px auto 28px;
}
.ts-v2-category-window-head span{
  color:#0071e3;
  font-weight:900;
}
.ts-v2-category-window-head h2{
  font-size:clamp(36px,6vw,70px);
  margin:6px 0;
  letter-spacing:-.06em;
}
.ts-v2-category-window-head p{
  color:#6e6e73;
  margin:0;
  font-size:18px;
}
.ts-v2-empty{
  grid-column:1/-1;
  text-align:center;
  padding:40px;
  background:#fff;
  border-radius:24px;
  color:#6e6e73;
  font-weight:800;
}
@media(max-width:1100px){
  .ts-v2-category-grid{grid-template-columns:repeat(3,1fr);}
  .ts-v2-featured-grid,.ts-v2-category-products{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:760px){
  .ts-v2-hero{
    grid-template-columns:1fr;
    min-height:auto;
    padding:92px 18px 42px;
    text-align:center;
  }
  .ts-v2-hero p{margin-left:auto;margin-right:auto;}
  .ts-v2-hero-actions{justify-content:center;}
  .ts-v2-hero-device{min-height:310px;}
  .ts-v2-hero-device img{max-height:320px;}
  .ts-v2-category-grid{grid-template-columns:repeat(2,1fr);gap:12px;}
  .ts-v2-category-card{min-height:185px;border-radius:24px;padding:16px;}
  .ts-v2-category-card h3{font-size:22px;margin-top:42px;}
  .ts-v2-featured-grid,.ts-v2-category-products{grid-template-columns:1fr;}
  .ts-v2-categories,.ts-v2-featured{padding:46px 16px;}
  .ts-v2-category-window{padding:18px;border-radius:26px;}
}


/* ===== ThinkStore FIX visual nota de entrega ===== */
#noteModal{
  z-index: 99999;
}
#noteModal:not(.open){
  display: none !important;
  pointer-events: none !important;
}
#noteModal.open{
  display: flex !important;
  pointer-events: auto !important;
}
#noteModal .close,
.note-card .close{
  position: sticky;
  top: 10px;
  float: right;
  z-index: 100000;
  cursor: pointer;
  pointer-events: auto;
}

/* ThinkStore portada nueva */
.hero-image img,.hero-right img,.ts-v2-hero-device img{
 content:url('assets/thinkstore_hero_new.jpg');
 width:min(700px,95%);
 max-height:520px;
 object-fit:contain;
 filter:drop-shadow(0 0 30px rgba(0,113,227,.25)) drop-shadow(0 25px 50px rgba(0,0,0,.45));
}


/* ===== ThinkStore portada iPhone fusionada ===== */
.ts-v2-hero{
  position: relative !important;
  overflow: hidden !important;
  min-height: 720px !important;
  padding-bottom: 150px !important;
  background:
    radial-gradient(circle at 78% 32%, rgba(0,113,227,.22), transparent 34%),
    radial-gradient(circle at 88% 66%, rgba(255,128,45,.13), transparent 26%),
    linear-gradient(135deg,#030711 0%,#071225 48%,#020617 100%) !important;
}

.ts-v2-hero::after{
  content:"";
  position:absolute;
  right:-2%;
  top:0;
  bottom:0;
  width:62%;
  background-image:
    linear-gradient(to right, rgba(3,7,17,1) 0%, rgba(3,7,17,.72) 10%, rgba(3,7,17,.18) 28%, rgba(3,7,17,0) 48%),
    linear-gradient(to bottom, rgba(3,7,17,.10), rgba(3,7,17,0) 38%, rgba(3,7,17,.20) 100%),
    url("assets/thinkstore_hero_iphone_fusion.jpg");
  background-size: cover;
  background-position: center right;
  background-repeat: no-repeat;
  z-index: 0;
  filter: drop-shadow(0 28px 50px rgba(0,0,0,.48));
}

.ts-v2-hero::before{
  content:"";
  position:absolute;
  right:8%;
  top:18%;
  width:38%;
  height:54%;
  background: radial-gradient(circle, rgba(0,113,227,.28), transparent 68%);
  filter: blur(36px);
  opacity:.85;
  z-index:0;
}

.ts-v2-hero > *{
  position:relative;
  z-index:2;
}

/* Ocultamos la imagen anterior del hero para usar la nueva como fondo integrado */
.ts-v2-hero-device{
  display:none !important;
}

/* Mantener texto a la izquierda con buena lectura */
.ts-v2-hero-content{
  max-width: 620px !important;
  position:relative;
  z-index:3;
}

/* Evita que botones/categorías queden cubiertos por la portada */
.ts-v2-categories,
#categorias-premium,
.category-tabs,
.quick-categories,
.hero-categories{
  position:relative !important;
  z-index:20 !important;
  margin-top:0 !important;
}

/* Ajustes móvil */
@media(max-width:900px){
  .ts-v2-hero{
    min-height: 680px !important;
    padding-top: 92px !important;
    padding-bottom: 120px !important;
  }

  .ts-v2-hero::after{
    right:-18%;
    top:auto;
    bottom:0;
    width:112%;
    height:54%;
    background-image:
      linear-gradient(to bottom, rgba(3,7,17,0) 0%, rgba(3,7,17,.18) 58%, rgba(3,7,17,.92) 100%),
      linear-gradient(to right, rgba(3,7,17,.70), rgba(3,7,17,0) 48%, rgba(3,7,17,.12)),
      url("assets/thinkstore_hero_iphone_fusion.jpg");
    background-size: cover;
    background-position: center right;
    opacity:.95;
  }

  .ts-v2-hero-content{
    max-width: 100% !important;
    text-align:center;
    margin:auto;
  }

  .ts-v2-hero-actions{
    justify-content:center;
  }
}


/* ===== FIX REAL: mover solo texto y botones del hero ===== */
.ts-v2-hero .ts-v2-hero-content{
  transform: translateX(190px) !important;
  max-width: 640px !important;
  text-align: left !important;
  align-items: flex-start !important;
}

.ts-v2-hero .ts-v2-hero-content .ts-v2-kicker,
.ts-v2-hero .ts-v2-hero-content h1,
.ts-v2-hero .ts-v2-hero-content p{
  text-align: left !important;
}

.ts-v2-hero .ts-v2-hero-actions{
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 18px !important;
  margin-top: 28px !important;
}

.ts-v2-hero .ts-v2-hero-actions .btn,
.ts-v2-hero .ts-v2-hero-actions button,
.ts-v2-hero .ts-v2-hero-actions a{
  min-width: 190px !important;
