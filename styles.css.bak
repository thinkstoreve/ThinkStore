  padding: 0 24px !important;
  border-radius: 999px !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1 !important;
  font-weight: 900 !important;
  letter-spacing: -0.01em !important;
  white-space: nowrap !important;
}

/* Colores por posición: Comprar ahora / Ver catálogo / WhatsApp */
.ts-v2-hero .ts-v2-hero-actions .btn:nth-child(1),
.ts-v2-hero .ts-v2-hero-actions button:nth-child(1),
.ts-v2-hero .ts-v2-hero-actions a:nth-child(1){
  background: linear-gradient(135deg,#0071e3,#0a84ff) !important;
  color: #fff !important;
  border: 0 !important;
  box-shadow: 0 14px 32px rgba(0,113,227,.35) !important;
}

.ts-v2-hero .ts-v2-hero-actions .btn:nth-child(2),
.ts-v2-hero .ts-v2-hero-actions button:nth-child(2),
.ts-v2-hero .ts-v2-hero-actions a:nth-child(2){
  background: rgba(255,255,255,.18) !important;
  color: #fff !important;
  border: 1px solid rgba(255,255,255,.38) !important;
  backdrop-filter: blur(18px) !important;
  box-shadow: 0 14px 30px rgba(0,0,0,.18) !important;
}

.ts-v2-hero .ts-v2-hero-actions .btn:nth-child(3),
.ts-v2-hero .ts-v2-hero-actions button:nth-child(3),
.ts-v2-hero .ts-v2-hero-actions a:nth-child(3){
  background: linear-gradient(135deg,#25d366,#12b957) !important;
  color: #fff !important;
  border: 0 !important;
  box-shadow: 0 14px 32px rgba(37,211,102,.28) !important;
}

/* No modificar imagen: solo asegurar que siga como está */
.ts-v2-hero::after,
.ts-v2-hero-device,
.ts-v2-hero-device img{
  /* se deja intacto */
}

/* Responsive */
@media(max-width:1100px){
  .ts-v2-hero .ts-v2-hero-content{
    transform: translateX(90px) !important;
  }
}

@media(max-width:900px){
  .ts-v2-hero .ts-v2-hero-content{
    transform: none !important;
    margin-left: 0 !important;
    max-width: 100% !important;
    text-align: center !important;
    align-items: center !important;
  }

  .ts-v2-hero .ts-v2-hero-content .ts-v2-kicker,
  .ts-v2-hero .ts-v2-hero-content h1,
